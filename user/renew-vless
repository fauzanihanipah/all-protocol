#!/bin/bash
. /usr/local/sbin/common.sh
header "PERPANJANG VLESS"
mapfile -t emails < <(jq -r '.inbounds[]|select(.tag=="vless-ws")|.settings.clients[].email' "$XRAY_CONFIG")
(( ${#emails[@]} == 0 )) && { warn "Tidak ada user."; press_enter; exit; }
i=0
for e in "${emails[@]}"; do i=$((i+1)); printf "  %2d) %s\n" "$i" "$e"; done
sline
read -rp " Pilih nomor: " n
[[ -z "$n" || "$n" -le 0 || "$n" -gt ${#emails[@]} ]] && { warn "Batal."; press_enter; exit; }
target="${emails[$((n-1))]}"
read -rp " Tambah berapa hari: " d
[[ -z "$d" ]] && d=30
new_exp=$(date -d "+$d days" +%s)
new_date=$(date -d "+$d days" +"%Y-%m-%d")
tmp=$(mktemp)
jq --arg t "$target" --argjson exp "$new_exp" '
  .inbounds |= map(
    if (.tag=="vless-ws" or .tag=="vless-grpc") then
       .settings.clients |= map(if .email==$t then .expiry=$exp else . end)
    else . end )
' "$XRAY_CONFIG" > "$tmp" && mv "$tmp" "$XRAY_CONFIG"
xray_restart
ok "User $target diperpanjang sampai $new_date"
press_enter

#!/bin/bash
# Main Menu - All-Protocol Tunnel
. /usr/local/sbin/common.sh

# -- gather VPS info --
ip_local="$IP"
[[ -z "$ip_local" ]] && ip_local=$(hostname -I | awk '{print $1}')
domain=$(cat /etc/xray/domain 2>/dev/null)
# Compact uptime: "1 day, 2 hours, 16 minutes" -> "1d 2h 16m" so it fits 33 cols.
uptime_str=$(uptime -p 2>/dev/null | sed -E '
    s/up //
    s/ years?,?/y/g
    s/ months?,?/mo/g
    s/ weeks?,?/w/g
    s/ days?,?/d/g
    s/ hours?,?/h/g
    s/ minutes?,?/m/g
    s/, / /g')
ram_used=$(free -m | awk '/Mem/ {print $3"M / "$2"M"}')
date_now=$(date '+%Y-%m-%d %H:%M')
bbr=$(bbr_status)
ipv6=$(ipv6_status)
os_name=$(. /etc/os-release; echo "$PRETTY_NAME" | sed 's/ (.*)//')

# -- compact one-line service status --
svc_one() { systemctl is-active --quiet "$1" && echo -e "${GREEN}${1%%-*}${NC}" || echo -e "${RED}${1%%-*}${NC}"; }
services_line=" $(svc_one ssh) $(svc_one dropbear) $(svc_one nginx) $(svc_one xray) $(svc_one "$STUNNEL_SVC") $(svc_one ws) $(svc_one runn)"

# -- active user counts --
ssh_n=$(awk -F: '($3>=1000)&&($1!="nobody"){print $1}' /etc/passwd | wc -l)
vmess_n=$(jq '[.inbounds[]|select(.tag=="vmess-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)
vless_n=$(jq '[.inbounds[]|select(.tag=="vless-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)
trojan_n=$(jq '[.inbounds[]|select(.tag=="trojan-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)

# -------------------------------------------------------------------
clear
top_line
title_row "ALL-PROTOCOL TUNNEL  -  CONTROL PANEL"
mid_line

# 3 compact info rows (left/right)
row2 " ${WHITE}IP    ${NC}: ${ip_local}"          " ${WHITE}OS    ${NC}: ${os_name}"
row2 " ${WHITE}Domain${NC}: ${domain:-(belum diset)}" " ${WHITE}Uptime${NC}: ${uptime_str:-?}"
row2 " ${WHITE}RAM   ${NC}: ${ram_used}"          " ${WHITE}Date  ${NC}: ${date_now}"
row2 " ${WHITE}BBR   ${NC}: ${bbr}"               " ${WHITE}IPv6  ${NC}: ${ipv6}"
mid_line

# Compact services row + users row
single_row " ${WHITE}Service${NC}:${services_line}"
single_row " ${WHITE}Users  ${NC}: ${YELLOW}SSH=${ssh_n}   VMess=${vmess_n}   VLess=${vless_n}   Trojan=${trojan_n}${NC}"
mid_line

# Menu options - 2 columns, 5 rows (10 items + Exit)
row2 "   ${GREEN}1${NC}) SSH / SSH-WS / SSH-SSL"   "   ${GREEN}6${NC}) Restart All Services"
row2 "   ${GREEN}2${NC}) V2Ray VMess"              "   ${GREEN}7${NC}) Toggle BBR"
row2 "   ${GREEN}3${NC}) V2Ray VLess"              "   ${GREEN}8${NC}) Toggle IPv6"
row2 "   ${GREEN}4${NC}) Trojan"                   "   ${GREEN}9${NC}) Update Script"
row2 "   ${GREEN}5${NC}) System & Tools"           "   ${RED}0${NC}) Exit"
bot_line

read -rp "                       Pilih menu : " opt
case $opt in
  1) m-ssh    ;;
  2) m-vmess  ;;
  3) m-vless  ;;
  4) m-trojan ;;
  5) m-system ;;
  6) systemctl restart ssh dropbear nginx xray "$STUNNEL_SVC" ws runn 2>/dev/null
     ok "Semua service di-restart."; press_enter ; menu ;;
  7) toggle-bbr   ; menu ;;
  8) toggle-ipv6  ; menu ;;
  9) update-script; menu ;;
  0) clear; exit 0 ;;
  *) fail "Pilihan tidak valid"; sleep 1; menu ;;
esac

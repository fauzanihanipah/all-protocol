#!/bin/bash
# Main Menu - All-Protocol Tunnel
. /usr/local/sbin/common.sh

# -- gather VPS info --
ip_local="$IP"
[[ -z "$ip_local" ]] && ip_local=$(hostname -I | awk '{print $1}')
domain=$(cat /etc/xray/domain 2>/dev/null)
uptime_str=$(uptime -p 2>/dev/null | sed 's/up //')
ram_used=$(free -m | awk '/Mem/ {print $3"M / "$2"M"}')
load_avg=$(awk '{print $1", "$2", "$3}' /proc/loadavg)
date_now=$(date '+%Y-%m-%d %H:%M')
bbr=$(bbr_status)
ipv6=$(ipv6_status)

# -- service status --
s_ssh=$(svc_status ssh);          s_dropb=$(svc_status dropbear)
s_ngx=$(svc_status nginx);        s_xray=$(svc_status xray)
s_stun=$(svc_status "$STUNNEL_SVC");    s_ws=$(svc_status ws)
s_udp=$(svc_status runn)

# -- active users --
ssh_n=$(awk -F: '($3>=1000)&&($1!="nobody"){print $1}' /etc/passwd | wc -l)
vmess_n=$(jq '[.inbounds[]|select(.tag=="vmess-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)
vless_n=$(jq '[.inbounds[]|select(.tag=="vless-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)
trojan_n=$(jq '[.inbounds[]|select(.tag=="trojan-ws")|.settings.clients[]]|length' "$XRAY_CONFIG" 2>/dev/null)

# -------------------------------------------------------------------
clear
top_line
single_row ""
title_row  "ALL-PROTOCOL TUNNEL  --  CONTROL PANEL"
single_row ""
mid_line

# left = VPS info        right = Service status
row2 " ${WHITE}IP        ${NC}: ${ip_local}"        " ${WHITE}ssh        ${NC}: ${s_ssh}"
row2 " ${WHITE}Domain    ${NC}: ${domain}"          " ${WHITE}dropbear   ${NC}: ${s_dropb}"
row2 " ${WHITE}Uptime    ${NC}: ${uptime_str}"      " ${WHITE}nginx      ${NC}: ${s_ngx}"
row2 " ${WHITE}Memory    ${NC}: ${ram_used}"        " ${WHITE}xray       ${NC}: ${s_xray}"
row2 " ${WHITE}Load Avg  ${NC}: ${load_avg}"        " ${WHITE}stunnel    ${NC}: ${s_stun}"
row2 " ${WHITE}Date      ${NC}: ${date_now}"        " ${WHITE}ws         ${NC}: ${s_ws}"
row2 " ${WHITE}BBR       ${NC}: ${bbr}"             " ${WHITE}udpgw      ${NC}: ${s_udp}"
row2 " ${WHITE}IPv6      ${NC}: ${ipv6}"            ""
mid_line

# active users summary (full-width row)
single_row " ${WHITE}Active Users${NC}  :  ${YELLOW}SSH=${ssh_n}   VMess=${vmess_n}   VLess=${vless_n}   Trojan=${trojan_n}${NC}"
mid_line

# Menu options - 2 columns
row2 "   ${GREEN}1${NC}) Menu SSH / SSH-WS / SSL"  "  ${GREEN}6${NC}) Restart All Services"
row2 "   ${GREEN}2${NC}) Menu V2Ray VMess"         "  ${GREEN}7${NC}) Toggle BBR"
row2 "   ${GREEN}3${NC}) Menu V2Ray VLess"         "  ${GREEN}8${NC}) Toggle IPv6"
row2 "   ${GREEN}4${NC}) Menu Trojan"              "  ${GREEN}9${NC}) Update Script"
row2 "   ${GREEN}5${NC}) Menu System"              "  ${RED}0${NC}) Exit"
bot_line

read -rp "                       Pilih menu : " opt
case $opt in
  1) m-ssh    ;;
  2) m-vmess  ;;
  3) m-vless  ;;
  4) m-trojan ;;
  5) m-system ;;
  6) systemctl restart ssh dropbear nginx xray "$STUNNEL_SVC" ws runn 2>/dev/null
     ok "Semua service di-restart."; press_enter ; menu ;;
  7) toggle-bbr   ; menu ;;
  8) toggle-ipv6  ; menu ;;
  9) update-script; menu ;;
  0) clear; exit 0 ;;
  *) fail "Pilihan tidak valid"; sleep 1; menu ;;
esac
